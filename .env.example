BOT_MODE=observe
BOT_POLICY_PATH=./config/bot-policy.local.json
BOT_LOG_LEVEL=info
BOT_LOG_REPLY_CONTENT=false
# Prefer per-profile/per-target retroactiveReply in bot-policy. This legacy
# switch makes all configured auto targets eligible for OpenClaw history catch-up.
BOT_PROCESS_EXISTING_MESSAGES=false

# OpenClaw worker settings. The retroactive reply scanner uses these values.
OPENCLAW_POLL_INTERVAL_MS=10000
OPENCLAW_READ_LIMIT=10
OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_ARGS=gateway run --force --allow-unconfigured
# OPENCLAW_COMMAND=node_modules\.bin\openclaw.cmd
# OPENCLAW_AGENTS_ASSISTANT_MODEL=openai-codex/gpt-5.4
# Set open to let OpenClaw receive every direct WhatsApp chat, while this
# project's bot-policy.local.json still decides who can get replies.
OPENCLAW_WHATSAPP_DM_POLICY=open
# OPENCLAW_NPX_PACKAGE=openclaw@2026.5.20
# OpenClaw 2026.5.x requires the WhatsApp channel as an external plugin:
# npm run openclaw:install-whatsapp

# Local HTTP bridge used by the OpenClaw dispatch plugin.
WHATSAPP_ASSISTANT_HOOK_HOST=127.0.0.1
WHATSAPP_ASSISTANT_HOOK_PORT=8790
WHATSAPP_ASSISTANT_HOOK_URL=http://127.0.0.1:8790/openclaw/message
WHATSAPP_ASSISTANT_DISPATCH_TIMEOUT_MS=120000

# Responder provider.
# Default: call an OpenAI-compatible API directly. This is the normal public
# setup and does not require Codex CLI or a ChatGPT/Codex subscription.
CODEX_PROXY_ENABLED=false
RESPONDER_BASE_URL=https://api.openai.com/v1
RESPONDER_API_KEY=your-api-key
RESPONDER_MODEL=gpt-4o-mini
RESPONDER_TIMEOUT_MS=60000
#
# Other OpenAI-compatible providers usually work by changing RESPONDER_BASE_URL,
# RESPONDER_API_KEY, and RESPONDER_MODEL.

# Structured weather lookup. Profiles must set tools.weather=true before this
# is used. Open-Meteo does not require an API key.
WEATHER_ENABLED=true
WEATHER_FORECAST_BASE_URL=https://api.open-meteo.com
WEATHER_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
WEATHER_GEOCODING_LANGUAGE=pt
# WEATHER_GEOCODING_COUNTRY_CODE=BR
WEATHER_TIMEOUT_MS=8000

# Optional local Codex CLI proxy for users who want to back replies with
# `codex exec` instead of a direct API key.
# CODEX_PROXY_ENABLED=true
# CODEX_PROXY_HOST=127.0.0.1
# CODEX_PROXY_PORT=8787
# CODEX_PROXY_API_KEY=dev-local-change-me
# CODEX_PROXY_MODEL=gpt-5.4
# CODEX_PROXY_TIMEOUT_MS=120000
# CODEX_PROXY_MAX_PROMPT_CHARS=20000
# CODEX_PROXY_SANDBOX=read-only
# CODEX_PROXY_ALLOW_WEB_SEARCH=true
# CODEX_PROXY_WORKDIR=.

# Optional audio transcription behind codex-proxy. This is useful when you want
# local Whisper, or when you want a single local proxy endpoint for everything.
CODEX_PROXY_TRANSCRIBER_PROVIDER=off
# CODEX_PROXY_TRANSCRIBER_PROVIDER=openai
# CODEX_PROXY_TRANSCRIBER_API_KEY=your-transcriber-api-key
# CODEX_PROXY_TRANSCRIBER_MODEL=gpt-4o-mini-transcribe
# CODEX_PROXY_TRANSCRIBER_PROVIDER=local-whisper
# CODEX_PROXY_TRANSCRIBER_BASE_URL=http://127.0.0.1:2022/v1
# CODEX_PROXY_TRANSCRIBER_MODEL=base
# CODEX_PROXY_TRANSCRIBER_TIMEOUT_MS=60000

# Codex-proxy responder mode.
# RESPONDER_BASE_URL=http://127.0.0.1:8787/v1
# RESPONDER_API_KEY=dev-local-change-me
# RESPONDER_MODEL=gpt-5.4
# RESPONDER_TIMEOUT_MS=120000

# Voice transcription. Profiles must explicitly enable voice before the worker
# transcribes audio messages. Direct API mode reuses RESPONDER_API_KEY unless
# TRANSCRIBER_API_KEY is set separately.
TRANSCRIBER_BASE_URL=https://api.openai.com/v1
# TRANSCRIBER_API_KEY=your-transcriber-api-key
TRANSCRIBER_MODEL=gpt-4o-mini-transcribe
TRANSCRIBER_TIMEOUT_MS=60000
# TRANSCRIBER_PROMPT=Mensagem de WhatsApp em portugues brasileiro.

# Optional local Whisper server managed by npm run warmup:whisper.
# Local Whisper also requires CODEX_PROXY_ENABLED=true because the worker sends
# transcription requests through codex-proxy in this mode.
WHISPER_LOCAL_MODEL=base
WHISPER_LOCAL_HOST=127.0.0.1
WHISPER_LOCAL_PORT=2022
# Set true if you want npm run warmup to also start the local Whisper server.
WHISPER_LOCAL_ENABLED=false
# WHISPER_LOCAL_THREADS=4
# WHISPER_LOCAL_COMMAND=C:\path\to\whisper-server.exe
# WHISPER_LOCAL_FFMPEG_COMMAND=C:\path\to\ffmpeg.exe

# Twilio direct-send smoke test. Do not commit real credentials.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CHANNEL=whatsapp
# TWILIO_FROM=whatsapp:+14155238886
# TWILIO_TO=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio inbound webhook. Configure this in Twilio as:
#   https://<your-public-tunnel>/twilio/whatsapp
TWILIO_WORKER_PORT=8791
TWILIO_WEBHOOK_PATH=/twilio/whatsapp
TWILIO_VALIDATE_SIGNATURE=true
# TWILIO_WEBHOOK_URL=https://example.ngrok-free.app/twilio/whatsapp
